# Skillforge environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. The `.env` file is NOT
# committed to git — keep it local. Rotate any token that has been exposed.
#
# Loading this file:
#   - For wrangler CLI commands (deploy, secret put, secret list):
#       set -a && source .env && set +a
#   - For the local Worker runtime (wrangler dev): use `.dev.vars` instead,
#     which wrangler auto-loads. Same keys, different file.
# -----------------------------------------------------------------------------

# Cloudflare API token — needed by wrangler to authenticate CLI calls.
# Create one with the "Edit Cloudflare Workers" template at
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Anthropic API key — used by the Worker when SKILLFORGE_PROVIDER=anthropic.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek API key — used by the Worker when SKILLFORGE_PROVIDER=deepseek
# (or when the /api/interview request overrides via ?provider=deepseek).
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
