# Copy to `.env` before running.

# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
# Local SQLite file (dev). For Turso or a remote libsql, use:
#   libsql://skillforge-<you>.turso.io
# and set TURSO_AUTH_TOKEN below.
DATABASE_URL=file:./db/skillforge.db
# TURSO_AUTH_TOKEN=

# ──────────────────────────────────────────────────────────────
# HTTP
# ──────────────────────────────────────────────────────────────
PORT=3000
# If set, serve the Astro static build from this folder alongside /api/*.
# Useful for single-origin setups (no CORS, cookies just work). Leave empty
# if nginx serves static separately.
STATIC_DIR=../dist

# ──────────────────────────────────────────────────────────────
# LLM providers
# ──────────────────────────────────────────────────────────────
SKILLFORGE_PROVIDER=deepseek
SKILLFORGE_MOCK_MODE=true
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────
# Model endpoint used by the backend's MCP runtime when an advisor has MCP
# toggled on. This IS the MCP server; only the model backend is external.
# Leave GEMMA_URL empty to fall back to DeepSeek (skill set still stays
# on the backend — client only sees assistant responses).
#
# When Gemma 4 is hosted (vLLM / Ollama / llama.cpp gateway), set:
#   GEMMA_URL=http://localhost:8080
#   GEMMA_TOKEN=secret           # optional
#   GEMMA_MODEL=gemma-4          # optional model hint
# ──────────────────────────────────────────────────────────────
GEMMA_URL=
GEMMA_TOKEN=
GEMMA_MODEL=

# ──────────────────────────────────────────────────────────────
# Admin
# ──────────────────────────────────────────────────────────────
ADMIN_EMAILS=hungkescy@gmail.com

# ──────────────────────────────────────────────────────────────
# Logging
# Leave empty to log to stdout only (systemd / docker capture). Set a path to
# ALSO append each line to a file. The folder is created if missing.
# ──────────────────────────────────────────────────────────────
LOG_FILE=./logs/backend.log
