{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skillforge",
  "main": "src/worker.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "vars": {
    "SKILLFORGE_PROVIDER": "deepseek"
  },
  "observability": {
    "enabled": true
  }
}
