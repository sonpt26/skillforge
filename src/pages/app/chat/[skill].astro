---
import Layout from "../../../layouts/Layout.astro";
import ChatRoom from "../../../components/ChatRoom";
import AdvisorHero from "../../../components/AdvisorHero.astro";
import { skills } from "../../../data/skills";

export function getStaticPaths() {
  return skills.map((s) => ({ params: { skill: s.id }, props: { skill: s } }));
}

const { skill } = Astro.props;
---

<Layout title={`${skill.name} — Private interview room`}>
  <section class="max-w-6xl mx-auto px-6 py-16">
    <a href="/#catalog" class="text-xs text-ink-500 hover:text-ink-800 transition">
      ← Back to catalog
    </a>

    <div class="mt-6 mb-8">
      <span class="text-[11px] uppercase tracking-[0.18em] text-ink-500">
        {skill.category} · Private Room
      </span>
      <h1 class="text-2xl md:text-3xl font-medium tracking-tight text-ink-900 mt-2 mb-2">
        {skill.name}
      </h1>
      <p class="text-sm text-ink-600 leading-relaxed max-w-2xl">
        A short private interview with {skill.advisor.name}'s playbook.
        Nothing is shared outside this room.
      </p>
    </div>

    <AdvisorHero advisor={skill.advisor} />

    <ChatRoom
      client:load
      skillId={skill.id}
      skillName={skill.name}
      advisorName={skill.advisor.name}
      advisorPortraitUrl={skill.advisor.portraitUrl}
    />
  </section>
</Layout>
