---
import Layout from "../../layouts/Layout.astro";
import { experts } from "../../data/experts";
import { templates as skillTemplates } from "../../data/skill-templates";
import { skills } from "../../data/skills";

export function getStaticPaths() {
  return experts.map((e) => ({ params: { id: e.id }, props: { expert: e } }));
}

const { expert } = Astro.props;

const authored = skillTemplates.filter((t) => t.expertId === expert.id);
const firstName = expert.name.split(" ")[0];

function compact(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + "k";
  return new Intl.NumberFormat("en-US").format(n);
}

const fullStars = Math.round(expert.stats.avgRating);
---

<Layout title={`${expert.name} — Skillforge advisor`}>
  <section class="max-w-6xl mx-auto px-6 py-12">
    <a
      href="/#catalog"
      class="text-xs text-ink-500 hover:text-ink-800 transition"
    >
      ← Back to catalog
    </a>

    <div class="mt-6 grid grid-cols-1 md:grid-cols-3 border border-ink-200">
      <div
        class="md:col-span-2 bg-ink-100 h-[440px] md:h-[560px] overflow-hidden"
      >
        <img
          src={expert.heroPortraitUrl ?? expert.portraitUrl}
          alt={expert.name}
          class="w-full h-full object-cover object-top"
        />
      </div>
      <div
        class="md:col-span-1 p-8 flex flex-col gap-4 bg-white border-t md:border-t-0 md:border-l border-ink-200"
      >
        <div class="text-[11px] uppercase tracking-[0.18em] text-accent-600">
          Advisor · {expert.yearsExperience}+ years
        </div>
        <h1
          class="text-3xl md:text-4xl font-medium tracking-tight leading-[1.1] text-ink-900"
        >
          {expert.name}
        </h1>
        <p class="text-sm text-ink-600 leading-snug">{expert.title}</p>
        <div class="flex items-center gap-2 mt-1">
          <div class="flex gap-0.5">
            {
              [0, 1, 2, 3, 4].map((i) => (
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill={i < fullStars ? "currentColor" : "none"}
                  stroke="currentColor"
                  stroke-width="1.5"
                  class={i < fullStars ? "text-accent-500" : "text-ink-300"}
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              ))
            }
          </div>
          <span class="text-sm text-ink-700 font-medium">
            {expert.stats.avgRating.toFixed(1)}
          </span>
          <span class="text-sm text-ink-400">
            · {compact(expert.stats.reviewCount)} reviews
          </span>
        </div>
        <ul class="text-sm text-ink-700 space-y-1 mt-1">
          <li>
            <span class="text-ink-900 font-medium">
              {compact(expert.stats.usersHelped)}+
            </span> teams helped
          </li>
          <li>
            <span class="text-ink-900 font-medium">
              {compact(expert.stats.downloads)}+
            </span> skills downloaded
          </li>
          <li>
            <span class="text-ink-900 font-medium">{authored.length}</span>
            {" "}template{authored.length === 1 ? "" : "s"} authored
          </li>
        </ul>
        {
          expert.approach && (
            <p class="text-sm text-ink-600 leading-relaxed italic border-l-2 border-accent-500 pl-3 mt-auto pt-3">
              {expert.approach}
            </p>
          )
        }
      </div>
    </div>

    <div
      class="border border-ink-200 border-t-0 grid grid-cols-2 md:grid-cols-4 gap-px bg-ink-200"
    >
      <div class="bg-white px-5 py-4">
        <div class="text-2xl font-medium text-ink-900 tracking-tight">
          {expert.stats.avgRating.toFixed(1)}
          <span class="text-base text-ink-400 font-normal">/ 5</span>
        </div>
        <div class="text-[11px] uppercase tracking-[0.14em] text-ink-500 mt-1">
          {compact(expert.stats.reviewCount)} reviews
        </div>
      </div>
      <div class="bg-white px-5 py-4">
        <div class="text-2xl font-medium text-ink-900 tracking-tight">
          {compact(expert.stats.usersHelped)}+
        </div>
        <div class="text-[11px] uppercase tracking-[0.14em] text-ink-500 mt-1">
          Teams helped
        </div>
      </div>
      <div class="bg-white px-5 py-4">
        <div class="text-2xl font-medium text-ink-900 tracking-tight">
          {compact(expert.stats.downloads)}+
        </div>
        <div class="text-[11px] uppercase tracking-[0.14em] text-ink-500 mt-1">
          Skill downloads
        </div>
      </div>
      <div class="bg-white px-5 py-4">
        <div class="text-2xl font-medium text-ink-900 tracking-tight">
          {authored.length}
        </div>
        <div class="text-[11px] uppercase tracking-[0.14em] text-ink-500 mt-1">
          Templates
        </div>
      </div>
    </div>

    {
      expert.specialties && expert.specialties.length > 0 && (
        <div class="mt-10">
          <h2 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-3">
            Specialties
          </h2>
          <div class="flex flex-wrap gap-2">
            {expert.specialties.map((s) => (
              <span class="text-sm border border-ink-200 bg-white px-3 py-1.5 text-ink-700">
                {s}
              </span>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-12 grid grid-cols-1 md:grid-cols-[1fr_280px] gap-10">
      <div>
        <h2
          class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-3"
        >
          Background
        </h2>
        <p class="text-base text-ink-800 leading-relaxed mb-8 max-w-prose">
          {expert.bio}
        </p>

        {
          expert.approach && (
            <>
              <h2 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-3">
                Approach
              </h2>
              <blockquote class="text-lg text-ink-900 leading-relaxed italic border-l-2 border-accent-500 pl-5 mb-8 max-w-prose">
                {expert.approach}
              </blockquote>
            </>
          )
        }

        <h2 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-3">
          Credentials
        </h2>
        <ul class="space-y-2 mb-8">
          {
            expert.credentials.map((c) => (
              <li class="flex gap-3 text-sm text-ink-700 leading-relaxed">
                <span class="mt-[9px] w-1 h-1 rounded-full bg-accent-500 shrink-0" />
                <span>{c}</span>
              </li>
            ))
          }
        </ul>
      </div>

      {
        expert.notableClients && expert.notableClients.length > 0 && (
          <aside class="border border-ink-200 bg-ink-50/60 p-5 self-start">
            <h3 class="text-[11px] uppercase tracking-[0.18em] text-ink-500 mb-3">
              Notable clients
            </h3>
            <ul class="space-y-1.5">
              {expert.notableClients.map((c) => (
                <li class="text-sm text-ink-800">{c}</li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>

    {
      authored.length > 0 && (
        <div class="mt-14">
          <h2 class="text-xl font-medium tracking-tight text-ink-900 mb-2">
            Templates from {firstName}
          </h2>
          <p class="text-sm text-ink-600 mb-5 max-w-2xl">
            Each of {firstName}'s playbooks becomes a personalized agent skill
            after a short private interview.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {authored.map((t) => {
              const cardSkill = skills.find((s) => s.id === t.id);
              return (
                <article class="border border-ink-200 bg-white p-5 flex flex-col">
                  <div class="text-[11px] uppercase tracking-[0.14em] text-ink-500 mb-2">
                    {t.category}
                  </div>
                  <h3 class="text-base font-medium text-ink-900 tracking-tight">
                    {t.name}
                  </h3>
                  <p class="text-sm text-ink-600 leading-relaxed mt-1.5 mb-3">
                    {t.tagline}
                  </p>
                  <p class="text-sm text-ink-500 leading-relaxed flex-1 mb-4">
                    {t.description}
                  </p>
                  <ul class="flex flex-wrap gap-1.5 mb-4">
                    {t.highlights.map((h) => (
                      <li class="text-xs text-ink-600 border border-ink-200 px-2 py-1">
                        {h}
                      </li>
                    ))}
                  </ul>
                  {cardSkill && (
                    <button
                      type="button"
                      data-skill-id={t.id}
                      class="bg-ink-900 text-ink-50 hover:bg-ink-700 text-sm px-4 py-2.5 self-start"
                      onclick={`window.dispatchEvent(new CustomEvent('skillforge:open-modal', { detail: { skillId: '${t.id}' } }))`}
                    >
                      Configure with {firstName} →
                    </button>
                  )}
                </article>
              );
            })}
          </div>
        </div>
      )
    }

    <div class="mt-14">
      <h2
        class="text-xl font-medium tracking-tight text-ink-900 mb-1 flex items-baseline gap-3"
      >
        <span>What customers say</span>
        <span class="text-sm text-ink-500 font-normal">
          {expert.reviews.length} recent · {expert.stats.reviewCount.toLocaleString()} total reviews
        </span>
      </h2>
      <div class="flex items-center gap-2 mb-5">
        <div class="flex gap-0.5">
          {
            [0, 1, 2, 3, 4].map((i) => (
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill={i < fullStars ? "currentColor" : "none"}
                stroke="currentColor"
                stroke-width="1.5"
                class={i < fullStars ? "text-accent-500" : "text-ink-300"}
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))
          }
        </div>
        <span class="text-sm text-ink-700 font-medium">
          {expert.stats.avgRating.toFixed(1)}
        </span>
        <span class="text-sm text-ink-400">/ 5</span>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          expert.reviews.map((r) => (
            <figure class="border border-ink-200 bg-ink-50 p-5">
              <blockquote class="text-sm text-ink-700 leading-relaxed">
                "{r.quote}"
              </blockquote>
              <figcaption class="mt-3 pt-3 border-t border-ink-200 text-xs">
                <div class="text-ink-900 font-medium">{r.name}</div>
                <div class="text-ink-500 mt-0.5">{r.role}</div>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  /* spacer to break the tight horizontal-rule look when a stat has no subtitle */
</style>
