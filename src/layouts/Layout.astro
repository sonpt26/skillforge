---
import "../styles/global.css";
import EntryModalMount from "../components/EntryModalMount";
import { skills } from "../data/skills";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Skillforge — Personalized agent skills for your team",
  description = "Buy a specialized AI agent skill, configured to your business. Runs locally with Claude Code and other agents.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1d1d1b" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-ink-200/80 bg-ink-50/80 backdrop-blur sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-ink-900">
          <span class="inline-block w-2 h-2 bg-accent-500 rounded-full"></span>
          <span class="font-medium tracking-tight">Skillforge</span>
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm text-ink-600">
          <a href="/#features" class="hover:text-ink-900 transition">Features</a>
          <a href="/#catalog" class="hover:text-ink-900 transition">Catalog</a>
          <a href="/#testimonials" class="hover:text-ink-900 transition">Customers</a>
          <a
            href="/become-an-advisor"
            class="hover:text-ink-900 transition"
          >
            Become an advisor
          </a>
          <a
            href="/#catalog"
            class="px-3.5 py-1.5 rounded-md bg-ink-900 text-ink-50 hover:bg-ink-700 transition text-sm"
          >
            Configure a skill
          </a>
        </nav>

        <details class="md:hidden relative mobile-menu group">
          <summary
            class="list-none cursor-pointer p-2 -mr-2 text-ink-700 hover:text-ink-900"
            aria-label="Open menu"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-open:hidden"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="hidden group-open:block"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </summary>
          <div
            class="absolute right-0 top-full mt-1 w-60 bg-white border border-ink-200 shadow-lg z-50"
          >
            <a
              href="/#features"
              class="block px-4 py-3 text-sm text-ink-700 hover:bg-ink-50 border-b border-ink-100"
              >Features</a
            >
            <a
              href="/#catalog"
              class="block px-4 py-3 text-sm text-ink-700 hover:bg-ink-50 border-b border-ink-100"
              >Catalog</a
            >
            <a
              href="/#testimonials"
              class="block px-4 py-3 text-sm text-ink-700 hover:bg-ink-50 border-b border-ink-100"
              >Customers</a
            >
            <a
              href="/become-an-advisor"
              class="block px-4 py-3 text-sm text-ink-700 hover:bg-ink-50 border-b border-ink-100"
              >Become an advisor</a
            >
            <a
              href="/#catalog"
              class="block px-4 py-3 text-sm font-medium text-ink-50 bg-ink-900 hover:bg-ink-700"
              >Configure a skill →</a
            >
          </div>
        </details>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <EntryModalMount client:load skills={skills} />

    <style>
      /* remove default triangle marker on the mobile-menu summary, cross-browser */
      details.mobile-menu > summary {
        list-style: none;
      }
      details.mobile-menu > summary::-webkit-details-marker {
        display: none;
      }
    </style>

    <script is:inline>
      // Close the mobile menu when the user taps outside or navigates.
      document.addEventListener("click", (e) => {
        const menu = document.querySelector("details.mobile-menu");
        if (!menu || !(menu instanceof HTMLDetailsElement)) return;
        if (!menu.open) return;
        if (!menu.contains(e.target)) menu.open = false;
      });
    </script>

    <footer class="border-t border-ink-200/80 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-sm text-ink-500">
        <div class="flex items-center gap-2">
          <span class="inline-block w-1.5 h-1.5 bg-accent-500 rounded-full"></span>
          <span>Skillforge — agent skills, configured to your business.</span>
        </div>
        <div class="flex items-center gap-6">
          <a href="#" class="hover:text-ink-800 transition">Privacy</a>
          <a href="#" class="hover:text-ink-800 transition">Terms</a>
          <a href="mailto:hello@skillforge.dev" class="hover:text-ink-800 transition">Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html>
