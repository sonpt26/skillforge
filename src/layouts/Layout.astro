---
import "../styles/global.css";
import EntryModalMount from "../components/EntryModalMount";
import { skills } from "../data/skills";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Skillforge — Personalized agent skills for your team",
  description = "Buy a specialized AI agent skill, configured to your business. Runs locally with Claude Code and other agents.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1d1d1b" />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-ink-200/80 bg-ink-50/80 backdrop-blur sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-ink-900">
          <span class="inline-block w-2 h-2 bg-accent-500 rounded-full"></span>
          <span class="font-medium tracking-tight">Skillforge</span>
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm text-ink-600">
          <a href="/#features" class="hover:text-ink-900 transition">Features</a>
          <a href="/#catalog" class="hover:text-ink-900 transition">Catalog</a>
          <a href="/#testimonials" class="hover:text-ink-900 transition">Customers</a>
          <a
            href="/become-an-advisor"
            class="hover:text-ink-900 transition"
          >
            Become an advisor
          </a>
          <a
            href="/#catalog"
            class="px-3.5 py-1.5 rounded-md bg-ink-900 text-ink-50 hover:bg-ink-700 transition text-sm"
          >
            Configure a skill
          </a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <EntryModalMount client:load skills={skills} />

    <footer class="border-t border-ink-200/80 mt-24">
      <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-sm text-ink-500">
        <div class="flex items-center gap-2">
          <span class="inline-block w-1.5 h-1.5 bg-accent-500 rounded-full"></span>
          <span>Skillforge — agent skills, configured to your business.</span>
        </div>
        <div class="flex items-center gap-6">
          <a href="#" class="hover:text-ink-800 transition">Privacy</a>
          <a href="#" class="hover:text-ink-800 transition">Terms</a>
          <a href="mailto:hello@skillforge.dev" class="hover:text-ink-800 transition">Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html>
